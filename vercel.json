{
  "framework": null,
  "buildCommand": "mkdir -p public && printf '<!doctype html><meta charset=\"utf-8\"><meta http-equiv=\"refresh\" content=\"0;url=https://ajink.in\"><title>Redirecting…</title><a href=\"https://ajink.in\">ajink.in</a>' > public/index.html",
  "outputDirectory": "public",
  "redirects": [
    {
      "source": "/:path*",
      "destination": "https://ajink.in/:path*",
      "statusCode": 307
    }
  ]
}
